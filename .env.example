PORT=3000

# Куда приходят заявки (для SMTP/Brevo; для Web3Forms email задаётся при регистрации ключа)
RECIPIENT_EMAIL=runatex.doc@mail.ru

# --- Рекомендуется для Render (бесплатный план) ---
# Web3Forms: только email, без данных компании
# 1. Откройте https://web3forms.com
# 2. Введите runatex.doc@mail.ru → получите access key на почту
WEB3FORMS_ACCESS_KEY=ваш-access-key

# --- Альтернатива (нужны данные компании) ---
# BREVO_API_KEY=ваш-api-ключ-brevo
# SENDER_EMAIL=runatex.doc@mail.ru

# --- Только для локального запуска (SMTP не работает на бесплатном Render) ---
# SMTP_HOST=smtp.mail.ru
# SMTP_PORT=465
# SMTP_USER=runatex.doc@mail.ru
# SMTP_PASS=пароль-для-внешнего-приложения
