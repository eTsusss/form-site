PORT=3000

# Куда приходят заявки
RECIPIENT_EMAIL=runatex.doc@mail.ru

# --- Вариант для Render (бесплатный план) ---
# Render блокирует SMTP-порты, поэтому используйте Brevo API:
# 1. Зарегистрируйтесь на https://www.brevo.com
# 2. Подтвердите отправителя: runatex.doc@mail.ru
# 3. Создайте API-ключ: SMTP & API → API Keys
BREVO_API_KEY=ваш-api-ключ-brevo
SENDER_EMAIL=runatex.doc@mail.ru

# --- Вариант для локального запуска (SMTP Mail.ru) ---
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=runatex.doc@mail.ru
SMTP_PASS=пароль-для-внешнего-приложения
